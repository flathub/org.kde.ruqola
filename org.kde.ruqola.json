{
    "id": "org.kde.ruqola",
    "runtime": "org.kde.Platform",
    "runtime-version": "6.10",
    "sdk": "org.kde.Sdk",
    "command": "ruqola",
    "rename-icon": "ruqola",
    "separate-locales": false,
    "finish-args": [
        "--device=dri",
        "--share=ipc",
        "--share=network",
        "--socket=fallback-x11",
        "--socket=pulseaudio",
        "--socket=wayland",
        "--talk-name=org.kde.StatusNotifierWatcher",
        "--talk-name=org.kde.kwalletd5"
    ],
    "cleanup": [
        "/include",
        "/lib/cmake",
        "/mkspecs",
        "/share/doc",
        "/share/qlogging-categories6"
    ],
    "modules": [
        {
            "name": "qtkeychain",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DCMAKE_INSTALL_LIBDIR=/app/lib",
                "-DLIB_INSTALL_DIR=/app/lib",
                "-DBUILD_TRANSLATIONS=NO",
                "-DBUILD_WITH_QT6=ON"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://github.com/frankosterfeld/qtkeychain/archive/refs/tags/0.15.0.tar.gz",
                    "sha256": "f4254dc8f0933b06d90672d683eab08ef770acd8336e44dfa030ce041dc2ca22",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 4138,
                        "stable-only": true,
                        "url-template": "https://github.com/frankosterfeld/qtkeychain/archive/refs/tags/$version.tar.gz"
                    }
                }
            ]
        },
        {
            "name": "ktextaddons",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/ktextaddons/ktextaddons-2.0.1.tar.xz",
                    "sha256": "b52356be07215f0ace0b8e2a6df8bcd8f3572ef5c0aff89631b043b10adb0c8a",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 351168,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/ktextaddons/ktextaddons-$version.tar.xz"
                    }
                }
            ]
        },
        {
            "name": "ruqola",
            "buildsystem": "cmake-ninja",
            "config-opts": [
                "-DBUILD_TESTING=OFF",
                "-DQT_MAJOR_VERSION=6"
            ],
            "builddir": true,
            "sources": [
                {
                    "type": "archive",
                    "url": "https://download.kde.org/stable/ruqola/ruqola-2.7.0.tar.xz",
                    "sha256": "b9880d408094a8271094414c290c93a07f0d0564a60227e7724dc3e252f0005c",
                    "x-checker-data": {
                        "type": "anitya",
                        "project-id": 272939,
                        "stable-only": true,
                        "url-template": "https://download.kde.org/stable/ruqola/ruqola-$version.tar.xz"
                    }
                }
            ]
        }
    ]
}
